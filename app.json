{
  "expo": {
    "name": "IronBranch",
    "slug": "ironbranch-player",
    "version": "1.1.1",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "versionCode": 5,
      "edgeToEdgeEnabled": true,
      "package": "com.alireza0x86.ironbranchplayer"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "a90f4a94-8e4d-4456-a1f3-b33ffaface4f"
      }
    },
    "plugins": ["expo-secure-store", "expo-font"]
  }
}
